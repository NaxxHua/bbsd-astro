---
import BaseLayout from "../layouts/BaseLayout.astro";
import ScrollReveal from "../components/animations/ScrollReveal.tsx";
import TextReveal from "../components/animations/TextReveal.tsx";
import GetInTouchBanner from "../components/common/GetInTouchBanner.tsx";
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Our Market - BBSD">
  <main>
    <!-- Hero -->
    <section class="relative h-screen w-full overflow-hidden">
      <img
        src={`${base}images/market/market-hero.jpg`}
        alt=""
        class="absolute inset-0 h-full w-full object-cover"
      />
      <div class="absolute inset-0 bg-black/40"></div>
      <div
        class="relative z-10 flex h-full flex-col items-center justify-center px-6 text-center"
      >
        <h1 class="mb-6 text-5xl font-bold text-white md:text-7xl">Our Market</h1>
        <p class="max-w-2xl text-base text-white/70 md:text-lg">
          Our journey has been marked by continuous improvement, expansion
          of our service offerings and a relentless focus on customer satisfaction.
        </p>
      </div>
    </section>

    <!-- Market Cards -->
    <section class="bg-blue-light py-24">
      <div class="mx-auto max-w-[1200px] px-6">
        <div class="mb-16 flex flex-col items-start justify-between gap-4 md:flex-row md:items-end">
          <TextReveal
            client:visible
            text="Our Market"
            tag="h2"
            className="text-3xl font-bold text-blue-dark md:text-5xl"
          />
          <p class="text-base text-gray italic md:text-lg">Where We Make an Impact.</p>
        </div>

        <div class="grid gap-8 md:grid-cols-3">
          <!-- FPSO -->
          <ScrollReveal client:visible>
            <div class="overflow-hidden rounded-2xl bg-white shadow-sm">
              <div class="aspect-[4/3] overflow-hidden">
                <img
                  src={`${base}images/home/offshore-crane.jpg`}
                  alt="FPSO Modulars"
                  loading="lazy"
                  class="h-full w-full object-cover"
                />
              </div>
              <div class="p-6">
                <h3 class="mb-3 text-lg font-bold text-dark">
                  OFFSHORE FPSO Modulars
                </h3>
                <p class="text-sm leading-relaxed text-gray">
                  Driving the future of energy with expertise in offshore wind,
                  hydrogen, and oil & gas, delivering safe, efficient, and
                  sustainable solutions.
                </p>
              </div>
            </div>
          </ScrollReveal>

          <!-- Renewable Energy -->
          <ScrollReveal client:visible delay={0.1}>
            <div class="overflow-hidden rounded-2xl bg-white shadow-sm">
              <div class="aspect-[4/3] overflow-hidden">
                <img
                  src={`${base}images/home/market-renewable.jpg`}
                  alt="Renewable Energy"
                  loading="lazy"
                  class="h-full w-full object-cover"
                />
              </div>
              <div class="p-6">
                <h3 class="mb-3 text-lg font-bold text-dark">
                  Renewable Energy
                </h3>
                <p class="text-sm leading-relaxed text-gray">
                  Building stronger cities through reliable engineering for
                  bridges, pipelines, and essential urban utilities, designed
                  for safety and long-term resilience.
                </p>
              </div>
            </div>
          </ScrollReveal>

          <!-- Onshore -->
          <ScrollReveal client:visible delay={0.2}>
            <div class="overflow-hidden rounded-2xl bg-white shadow-sm">
              <div class="aspect-[4/3] overflow-hidden">
                <img
                  src={`${base}images/home/market-onshore.jpg`}
                  alt="Onshore Plant Modulars"
                  loading="lazy"
                  class="h-full w-full object-cover"
                />
              </div>
              <div class="p-6">
                <h3 class="mb-3 text-lg font-bold text-dark">
                  Onshore Plant Modulars
                </h3>
                <p class="text-sm leading-relaxed text-gray">
                  Your trusted partner for cross-border projects, combining
                  local expertise and compliance to ensure seamless execution
                  between China and Europe.
                </p>
              </div>
            </div>
          </ScrollReveal>
        </div>
      </div>
    </section>

    <GetInTouchBanner client:visible />
  </main>
</BaseLayout>
