---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ScrollReveal from "../../components/animations/ScrollReveal.tsx";
import GetInTouchBanner from "../../components/common/GetInTouchBanner.tsx";
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Engineering Services - BBSD">
  <main>
    <!-- Hero -->
    <section class="relative h-screen w-full overflow-hidden">
      <img
        src={`${base}images/services/services-hero.jpg`}
        alt=""
        class="absolute inset-0 h-full w-full object-cover"
      />
      <div class="absolute inset-0 bg-black/40"></div>
      <div
        class="relative z-10 flex h-full flex-col items-center justify-center px-6 text-center"
      >
        <h1 class="text-6xl font-bold text-white/80 md:text-8xl">
          Engineering Services
        </h1>
      </div>
    </section>

    <!-- Disciplines -->
    <section class="bg-white py-20">
      <div class="mx-auto max-w-[1200px] px-6">
        <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
          <ScrollReveal client:visible>
            <a
              href={`${base}engineering-services/e-i-engineering`}
              class="group block overflow-hidden rounded-xl border border-gray-light/20 transition-shadow hover:shadow-lg"
            >
              <img
                src={`${base}images/services/service-1.jpg`}
                alt="E&I Engineering"
                class="h-48 w-full object-cover transition-transform group-hover:scale-105"
              />
              <div class="p-5">
                <h3 class="text-lg font-bold text-dark">
                  Electrical & Instrumentation
                </h3>
              </div>
            </a>
          </ScrollReveal>

          <ScrollReveal client:visible>
            <a
              href={`${base}engineering-services/mechanical-engineering`}
              class="group block overflow-hidden rounded-xl border border-gray-light/20 transition-shadow hover:shadow-lg"
            >
              <img
                src={`${base}images/services/service-4.jpg`}
                alt="Mechanical Engineering"
                class="h-48 w-full object-cover transition-transform group-hover:scale-105"
              />
              <div class="p-5">
                <h3 class="text-lg font-bold text-dark">
                  Mechanical Equipment
                </h3>
              </div>
            </a>
          </ScrollReveal>

          <ScrollReveal client:visible>
            <a
              href={`${base}engineering-services/piping-engineering`}
              class="group block overflow-hidden rounded-xl border border-gray-light/20 transition-shadow hover:shadow-lg"
            >
              <img
                src={`${base}images/services/service-3.jpg`}
                alt="Piping Engineering"
                class="h-48 w-full object-cover transition-transform group-hover:scale-105"
              />
              <div class="p-5">
                <h3 class="text-lg font-bold text-dark">Piping & Components</h3>
              </div>
            </a>
          </ScrollReveal>

          <ScrollReveal client:visible>
            <a
              href={`${base}engineering-services/structural-engineering`}
              class="group block overflow-hidden rounded-xl border border-gray-light/20 transition-shadow hover:shadow-lg"
            >
              <img
                src={`${base}images/services/service-2.jpg`}
                alt="Structural Engineering"
                class="h-48 w-full object-cover transition-transform group-hover:scale-105"
              />
              <div class="p-5">
                <h3 class="text-lg font-bold text-dark">
                  Fasteners & Accessories
                </h3>
              </div>
            </a>
          </ScrollReveal>
        </div>
      </div>
    </section>

    <GetInTouchBanner client:visible />
  </main>
</BaseLayout>
