---
import BaseLayout from "../../layouts/BaseLayout.astro";
import GetInTouchBanner from "../../components/common/GetInTouchBanner.tsx";
---

<BaseLayout title="Structural Engineering - BBSD">
  <main>
    <!-- Hero -->
    <section class="relative h-[60vh] min-h-[400px] w-full overflow-hidden">
      <img
        src="/images/services/service-2.jpg"
        alt=""
        class="absolute inset-0 h-full w-full object-cover"
      />
      <div class="absolute inset-0 bg-black/50"></div>
      <div
        class="relative z-10 flex h-full flex-col items-center justify-center px-6 text-center"
      >
        <h1 class="mb-4 text-4xl font-bold text-white md:text-6xl">
          Structural Engineering
        </h1>
      </div>
    </section>

    <!-- Content -->
    <section class="bg-white py-20">
      <div class="mx-auto max-w-[1200px] px-6">
        <p class="mb-12 max-w-3xl text-sm leading-relaxed text-gray">
          BBSD offers structural engineering services for both onshore and
          offshore complex structures. The structural engineering services
          includes but not limited to:
        </p>

        <div class="grid gap-16">
          <!-- Analysis -->
          <div>
            <h2 class="mb-4 text-2xl font-bold text-dark">
              Analysis / Calculations
            </h2>
            <p class="mb-4 text-sm leading-relaxed text-gray">
              Analysis & Calculations for large scale structures and complex
              detail joints are performed by our experienced engineers using
              Finite Element Analysis Software. Our structural engineers are
              familiar with most industry standards and practices, for instance
              DNV rules, API RP 2A, ISO 19901/19902, Eurocode 1993.
            </p>
            <ul class="space-y-2 text-sm text-gray">
              <li class="flex items-start gap-2">
                <span class="mt-1 text-orange-primary">•</span>Static and
                Dynamic analysis
              </li>
              <li class="flex items-start gap-2">
                <span class="mt-1 text-orange-primary">•</span>Fatigue Analysis
                for welded joints at offshore structures
              </li>
              <li class="flex items-start gap-2">
                <span class="mt-1 text-orange-primary">•</span>Vibration
                Analysis for Rotating Machines mounted on structure
              </li>
              <li class="flex items-start gap-2">
                <span class="mt-1 text-orange-primary">•</span>Complex Analysis
                for Blast Loading, Earthquake Loading, Stochastic wave Loading
              </li>
            </ul>
          </div>

          <!-- 3D Modelling -->
          <div>
            <h2 class="mb-4 text-2xl font-bold text-dark">
              Design in 3D Modelling with Cutting Edge BIM Tools
            </h2>
            <p class="mb-4 text-sm leading-relaxed text-gray">
              3D Modelling for various types of structures with large and small
              scales are realized by our experienced designers using cutting
              edge BIM Software. With in-house developed algorithm and
              customized scripted macros, we can automize the design workflow in
              a flawless way.
            </p>
            <ul class="space-y-2 text-sm text-gray">
              <li class="flex items-start gap-2">
                <span class="mt-1 text-orange-primary">•</span>Offshore Topside
                Modules and Skids
              </li>
              <li class="flex items-start gap-2">
                <span class="mt-1 text-orange-primary">•</span>Onshore Plants
                and Technical buildings
              </li>
              <li class="flex items-start gap-2">
                <span class="mt-1 text-orange-primary">•</span>Civil and
                Architectural Structures
              </li>
            </ul>
          </div>

          <!-- Drawings -->
          <div>
            <h2 class="mb-4 text-2xl font-bold text-dark">
              Drawings (Design Drawings & Shop Drawings)
            </h2>
            <p class="mb-4 text-sm leading-relaxed text-gray">
              Drawings are produced accurately from the 3D BIM model. The
              drawings are closely monitored and updated according to the latest
              design status with other disciplines like E&I, Piping and
              Mechanical.
            </p>
            <ul class="space-y-2 text-sm text-gray">
              <li class="flex items-start gap-2">
                <span class="mt-1 text-orange-primary">•</span>Structural GA
                Drawing
              </li>
              <li class="flex items-start gap-2">
                <span class="mt-1 text-orange-primary">•</span>Detailed Drawings
                for Joints and Connections
              </li>
              <li class="flex items-start gap-2">
                <span class="mt-1 text-orange-primary">•</span>Fabrication Shop
                Drawings
              </li>
            </ul>
          </div>
        </div>

        <!-- Navigation -->
        <div class="mt-16 flex justify-start">
          <a
            href="/engineering-services/piping-engineering"
            class="text-sm font-medium text-blue-link hover:underline"
            >‹ Piping Engineering</a
          >
        </div>
      </div>
    </section>

    <GetInTouchBanner client:visible />
  </main>
</BaseLayout>
