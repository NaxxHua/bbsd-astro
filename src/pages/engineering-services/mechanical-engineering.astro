---
import BaseLayout from "../../layouts/BaseLayout.astro";
import GetInTouchBanner from "../../components/common/GetInTouchBanner.tsx";
---

<BaseLayout title="Mechanical Engineering - BBSD">
  <main>
    <!-- Hero -->
    <section class="relative h-[60vh] min-h-[400px] w-full overflow-hidden">
      <img
        src="/images/services/service-4.jpg"
        alt=""
        class="absolute inset-0 h-full w-full object-cover"
      />
      <div class="absolute inset-0 bg-black/50"></div>
      <div
        class="relative z-10 flex h-full flex-col items-center justify-center px-6 text-center"
      >
        <h1 class="mb-4 text-4xl font-bold text-white md:text-6xl">
          Mechanical Engineering
        </h1>
      </div>
    </section>

    <!-- Content -->
    <section class="bg-white py-20">
      <div class="mx-auto max-w-[1200px] px-6">
        <p class="mb-12 max-w-3xl text-sm leading-relaxed text-gray">
          BBSD offers mechanical engineering services for both onshore and
          offshore plants. The mechanical engineering focuses on the
          specification, design, selection, and integration of static and
          rotating equipment to ensure safe, reliable, and efficient operation
          in harsh offshore environments.
        </p>

        <div class="grid gap-16">
          <!-- Equipment Design -->
          <div>
            <h2 class="mb-4 text-2xl font-bold text-dark">
              Equipment Design and Specification
            </h2>
            <p class="mb-4 text-sm leading-relaxed text-gray">
              Equipment Design collects design inputs from Process data sheets
              and P&ID's and define design criteria for equipment selection and
              sizing. The design ensure compliance with standards like ASME
              Section VIII, API 617, API 650, API 660, API 680, TEMA.
            </p>
            <ul class="space-y-2 text-sm text-gray">
              <li class="flex items-start gap-2">
                <span class="mt-1 text-orange-primary">•</span>Static Equipment:
                Pressure vessels, storage tanks, filters and heat exchangers
              </li>
              <li class="flex items-start gap-2">
                <span class="mt-1 text-orange-primary">•</span>Rotating
                Equipment: Pumps, Compressors, Turbines
              </li>
              <li class="flex items-start gap-2">
                <span class="mt-1 text-orange-primary">•</span>Skid-mounted and
                packaged units: WHRU & HRSG
              </li>
            </ul>
          </div>

          <!-- Vendor Engagement -->
          <div>
            <h2 class="mb-4 text-2xl font-bold text-dark">
              Vendor Engagement and Procurement Support
            </h2>
            <p class="mb-4 text-sm leading-relaxed text-gray">
              Vendor Engagement and Procurement Support with our hands-on
              dedicated mechanical engineers is the key success for on-time
              delivery of various equipment.
            </p>
            <ul class="space-y-2 text-sm text-gray">
              <li class="flex items-start gap-2">
                <span class="mt-1 text-orange-primary">•</span>Prepare Material
                Requisitions (MRs) for procurement and conduct technical bid
                evaluations (TBEs)
              </li>
              <li class="flex items-start gap-2">
                <span class="mt-1 text-orange-primary">•</span>Review and
                approve vendor drawings, datasheets, and calculations
              </li>
              <li class="flex items-start gap-2">
                <span class="mt-1 text-orange-primary">•</span>Coordinate
                Factory Acceptance Tests (FATs) and witness critical inspections
              </li>
            </ul>
          </div>

          <!-- Integration -->
          <div>
            <h2 class="mb-4 text-2xl font-bold text-dark">
              Integration with Plant Layout Design
            </h2>
            <p class="mb-4 text-sm leading-relaxed text-gray">
              Integration with Layout is the key for offshore plant design which
              requires complicated multiciliary coordination with piping layout
              design, E&I design and Structural Design.
            </p>
            <ul class="space-y-2 text-sm text-gray">
              <li class="flex items-start gap-2">
                <span class="mt-1 text-orange-primary">•</span>Provide equipment
                layout guidance to ensure optimized operations and efficient
                installation
              </li>
              <li class="flex items-start gap-2">
                <span class="mt-1 text-orange-primary">•</span>Work with
                structural engineers to confirm foundation, skid, and support
                design
              </li>
              <li class="flex items-start gap-2">
                <span class="mt-1 text-orange-primary">•</span>Collaborate with
                piping teams to verify nozzle loads and thermal expansion
                allowances
              </li>
              <li class="flex items-start gap-2">
                <span class="mt-1 text-orange-primary">•</span>Produce
                mechanical handling report and layout for plant maintenance and
                operations
              </li>
            </ul>
          </div>
        </div>

        <!-- Navigation -->
        <div class="mt-16 flex justify-between">
          <a
            href="/engineering-services/e-i-engineering"
            class="text-sm font-medium text-blue-link hover:underline"
            >‹ E&I Engineering</a
          >
          <a
            href="/engineering-services/piping-engineering"
            class="text-sm font-medium text-blue-link hover:underline"
            >Piping Engineering ›</a
          >
        </div>
      </div>
    </section>

    <GetInTouchBanner client:visible />
  </main>
</BaseLayout>
