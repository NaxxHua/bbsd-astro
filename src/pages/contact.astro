---
import BaseLayout from "../layouts/BaseLayout.astro";
import ScrollReveal from "../components/animations/ScrollReveal.tsx";
import ImageCarousel from "../components/contact/ImageCarousel.tsx";
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Contact - BBSD">
  <main>
    <!-- Hero -->
    <section class="relative h-screen w-full overflow-hidden">
      <img
        src={`${base}images/contact/hero.jpg`}
        alt=""
        class="absolute inset-0 h-full w-full object-cover"
      />
      <div class="absolute inset-0 bg-black/40"></div>
      <div
        class="relative z-10 flex h-full flex-col items-center justify-center px-6 text-center"
      >
        <h1 class="mb-6 text-6xl font-bold text-white/80 md:text-8xl">
          Contact
        </h1>
        <p class="max-w-2xl text-base text-white/70 md:text-lg">
          Contact BBSD today and take the first step towards reliable and professional solutions.
        </p>
      </div>
    </section>

    <!-- Contact Form + Info -->
    <section class="bg-white py-20">
      <div class="mx-auto max-w-[1200px] px-6">
        <div class="grid gap-16 lg:grid-cols-2">
          <!-- Left: Info -->
          <ScrollReveal client:visible>
            <div>
              <h2 class="mb-6 text-3xl font-bold leading-tight text-dark md:text-5xl">
                Let's get in touch and work together!
              </h2>
              <p class="mb-8 text-base leading-relaxed text-gray">
                Whether you're dealing with an emergency, need routine maintenance,
                or have a question about our services, our team at BBSD is ready to
                assist you.
              </p>
              <div class="flex items-center gap-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-blue-dark">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <a href="tel:+8615927327738" class="text-lg font-semibold text-dark">(86) 15927327738</a>
              </div>
              <div class="mt-4 flex items-center gap-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-blue-dark">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <p class="text-sm text-gray">No. 218 Yongxing Road, Yongxing Sub-district, Chongchuan District, Nantong, Jiangsu, China</p>
              </div>
              <div class="mt-4 flex items-center gap-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-blue-dark">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <a href="mailto:jacklu@bbsd.cn.com" class="text-sm text-gray">jacklu@bbsd.cn.com</a>
              </div>
            </div>
          </ScrollReveal>

          <!-- Right: Form Card -->
          <ScrollReveal client:visible>
            <div class="rounded-2xl bg-blue-light p-8">
              <h3 class="mb-6 text-center text-xl font-bold text-orange-primary">Send us a message</h3>
              <form class="space-y-4">
                <input
                  type="text"
                  name="name"
                  placeholder="Your name"
                  required
                  class="w-full rounded-lg bg-white px-4 py-3 text-sm text-dark outline-none placeholder:text-gray-light"
                />
                <input
                  type="email"
                  name="email"
                  placeholder="name@gmail.com"
                  required
                  class="w-full rounded-lg bg-white px-4 py-3 text-sm text-dark outline-none placeholder:text-gray-light"
                />
                <textarea
                  name="message"
                  rows="4"
                  placeholder="How can we help?"
                  required
                  class="w-full resize-none rounded-lg bg-white px-4 py-3 text-sm text-dark outline-none placeholder:text-gray-light"
                ></textarea>
                <button
                  type="submit"
                  class="w-full rounded-lg bg-orange-primary py-4 text-base font-semibold text-white transition-colors hover:bg-orange-hover"
                >Send message</button>
              </form>
            </div>
          </ScrollReveal>
        </div>
      </div>
    </section>

    <!-- Image Carousel -->
    <section class="bg-white pb-10">
      <ImageCarousel client:visible />
    </section>

    <!-- Google Maps -->
    <section class="bg-white py-10">
      <div class="mx-auto max-w-[1200px] px-6">
        <div class="overflow-hidden rounded-xl">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3417.5!2d120.86!3d32.01!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMzLCsDAwJzM2LjAiTiAxMjDCsDUxJzM2LjAiRQ!5e0!3m2!1sen!2s!4v1234567890"
            width="100%"
            height="400"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="BBSD Nantong Office Location"></iframe>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
