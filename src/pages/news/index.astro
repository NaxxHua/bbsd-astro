---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ScrollReveal from "../../components/animations/ScrollReveal.tsx";
import GetInTouchBanner from "../../components/common/GetInTouchBanner.tsx";

const base = import.meta.env.BASE_URL;
const articles = [
  {
    slug: "bbsd-first-year-anniversary",
    title: "BBSD - First Year Anniversary",
    date: "Nov 20, 2025",
    image: `${base}images/news/anniversary.jpg`,
  },
  {
    slug: "our-company-signs-industry-university-research-strategic-cooperation-agreement-with-nantong-university",
    title:
      "Our Company Signs Industry-University-Research Strategic Cooperation Agreement with Nantong University",
    date: "Apr 18, 2025",
    image: `${base}images/news/signing.jpg`,
  },
  {
    slug: "launches-iso-9000-quality-management-system-certification",
    title:
      "BBSD (Jiangsu Nantong) Engineering Technology Co., Ltd. Officially Launches ISO 9000 Quality Management System Certification",
    date: "Jun 4, 2025",
    image: `${base}images/news/iso-article.jpg`,
  },
  {
    slug: "successfully-holds-fire-safety-emergency-drill",
    title:
      "BBSD (Jiangsu Nantong) Engineering Technology Co., Ltd. Successfully Holds Fire Safety Emergency Drill",
    date: "Aug 27, 2025",
    image: `${base}images/news/fire-drill.jpg`,
  },
];
---

<BaseLayout title="Latest News - BBSD">
  <main>
    <!-- Hero -->
    <section class="relative h-screen w-full overflow-hidden">
      <img
        src={`${base}images/home/welder.jpg`}
        alt=""
        class="absolute inset-0 h-full w-full object-cover"
      />
      <div class="absolute inset-0 bg-black/40"></div>
      <div
        class="relative z-10 flex h-full flex-col items-center justify-center px-6 text-center"
      >
        <h1 class="mb-6 text-6xl font-bold text-white/80 md:text-8xl">Latest News</h1>
        <p class="max-w-2xl text-base text-white/70 md:text-lg">
          Our blog is designed to help you understand your plumbing system
          better and provide valuable insights to keep it running smoothly.
        </p>
      </div>
    </section>

    <!-- Articles Grid -->
    <section class="bg-white pb-20">
      <div class="mx-auto max-w-[1200px] px-6">
        <div class="grid gap-8 md:grid-cols-2">
          {
            articles.map((article) => (
              <ScrollReveal client:visible>
                <a
                  href={`${base}news/${article.slug}`}
                  class="group block overflow-hidden rounded-2xl border border-gray-light/20 transition-shadow hover:shadow-lg"
                >
                  <img
                    src={article.image}
                    alt={article.title}
                    loading="lazy"
                    class="h-64 w-full object-cover transition-transform group-hover:scale-105"
                  />
                  <div class="p-6">
                    <p class="mb-2 text-xs text-gray-light">{article.date}</p>
                    <h3 class="mb-3 text-lg font-bold leading-tight text-dark">
                      {article.title}
                    </h3>
                    <span class="text-sm font-medium text-orange-primary">
                      Read more →
                    </span>
                  </div>
                </a>
              </ScrollReveal>
            ))
          }
        </div>
      </div>
    </section>

    <GetInTouchBanner client:visible />
  </main>
</BaseLayout>
