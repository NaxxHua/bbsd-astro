---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ScrollReveal from "../../components/animations/ScrollReveal.tsx";
import TextReveal from "../../components/animations/TextReveal.tsx";
import GetInTouchBanner from "../../components/common/GetInTouchBanner.tsx";
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Our Projects - BBSD">
  <main>
    <!-- Hero -->
    <section class="relative h-screen w-full overflow-hidden">
      <img
        src={`${base}images/market/hero.jpg`}
        alt=""
        class="absolute inset-0 h-full w-full object-cover"
      />
      <div class="absolute inset-0 bg-black/40"></div>
      <div
        class="relative z-10 flex h-full flex-col items-center justify-center px-6 text-center"
      >
        <h1 class="mb-6 text-6xl font-bold text-white/80 md:text-8xl">Our Projects</h1>
        <p class="max-w-2xl text-base text-white/70 md:text-lg">
          Our journey has been marked by continuous improvement, expansion
          of our service offerings and a relentless focus on customer satisfaction.
        </p>
      </div>
    </section>

    <!-- Projects List -->
    <section class="bg-white py-20">
      <div class="mx-auto max-w-[1200px] px-6">
        <TextReveal
          client:visible
          text="Our Projects"
          tag="h2"
          className="mb-4 text-3xl font-bold text-blue-dark md:text-5xl"
        />
        <p class="mb-12 text-lg text-gray">Where We Make an Impact.</p>

        <div class="grid gap-8 md:grid-cols-2">
          <ScrollReveal client:visible>
            <a
              href={`${base}projects/projetcs`}
              class="group block overflow-hidden rounded-2xl border border-gray-light/20 transition-shadow hover:shadow-lg"
            >
              <img
                src={`${base}images/projects/nag-project.jpg`}
                alt="Abigail Joseph NAG Project"
                class="h-64 w-full object-cover transition-transform group-hover:scale-105"
              />
              <div class="p-6">
                <h3 class="text-xl font-bold text-dark">
                  Abigail Joseph – NAG Project
                </h3>
              </div>
            </a>
          </ScrollReveal>

          <ScrollReveal client:visible>
            <div
              class="flex h-full items-center justify-center rounded-2xl border border-dashed border-gray-light/40 p-6"
            >
              <p class="text-lg font-medium text-gray-light">More to come</p>
            </div>
          </ScrollReveal>
        </div>
      </div>
    </section>

    <GetInTouchBanner client:visible />
  </main>
</BaseLayout>
