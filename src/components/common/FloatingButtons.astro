---
const base = import.meta.env.BASE_URL;
---

<div class="fixed bottom-4 left-4 z-40 flex items-center gap-2 md:bottom-6 md:left-5">
  <a
    href={`${base}contact`}
    class="flex items-center gap-1.5 rounded-full bg-dark px-4 py-2 text-xs font-medium text-white shadow-lg transition-transform hover:scale-105 md:gap-2 md:px-5 md:py-2.5 md:text-sm"
  >
    <span class="text-[10px] md:text-xs">✦</span>
    Contact us
  </a>
  <a
    href={`${base}careers`}
    class="flex items-center gap-1.5 rounded-full border border-dark/10 bg-white px-4 py-2 text-xs font-medium text-dark shadow-lg transition-transform hover:scale-105 md:gap-2 md:px-5 md:py-2.5 md:text-sm"
  >
    Join us
  </a>
</div>
