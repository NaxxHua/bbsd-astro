---
const year = new Date().getFullYear();
---

<footer class="bg-dark text-white">
  <div class="mx-auto max-w-[1200px] px-6 py-16">
    <div class="grid gap-12 md:grid-cols-3">
      <!-- Logo & Description -->
      <div>
        <a href="/">
          <img src="/images/home/logo.png" alt="BBSD" class="mb-4 h-8 w-auto" />
        </a>
        <p class="text-sm leading-relaxed text-gray-light">
          BBSD is a professional engineering service provider specializing in
          offshore, renewable energy, and onshore plant modular projects.
        </p>
      </div>

      <!-- Rotterdam Office -->
      <div>
        <h4
          class="mb-3 text-sm font-semibold uppercase tracking-wider text-orange-primary"
        >
          Rotterdam Office
        </h4>
        <address class="text-sm leading-relaxed text-gray-light not-italic">
          Weena 505, 3013 AL<br />
          Rotterdam, Netherlands
        </address>
      </div>

      <!-- Nantong Office -->
      <div>
        <h4
          class="mb-3 text-sm font-semibold uppercase tracking-wider text-orange-primary"
        >
          Nantong Office
        </h4>
        <address class="text-sm leading-relaxed text-gray-light not-italic">
          No. 8 Tongsheng Avenue, Nantong<br />
          Jiangsu, China 226000
        </address>
      </div>
    </div>

    <!-- Bottom bar -->
    <div
      class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-white/10 pt-8 md:flex-row"
    >
      <p class="text-xs text-gray-light">
        &copy; {year} BBSD. All rights reserved.
      </p>
      <nav class="flex gap-6 text-xs">
        <a href="/" class="text-gray-light transition-colors hover:text-white"
          >Home</a
        >
        <a
          href="/about-us"
          class="text-gray-light transition-colors hover:text-white">About</a
        >
        <a
          href="/contact"
          class="text-gray-light transition-colors hover:text-white">Contact</a
        >
        <a
          href="/news"
          class="text-gray-light transition-colors hover:text-white">News</a
        >
      </nav>
    </div>
  </div>
</footer>
