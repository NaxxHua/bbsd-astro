---
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
---

<footer class="bg-white text-dark">
  <div class="mx-auto max-w-[1200px] px-5 py-12 md:px-6 md:py-16">
    <div class="grid gap-10 md:grid-cols-3 md:gap-12">
      <!-- Logo & Description -->
      <div>
        <a href={base}>
          <img src={`${base}images/home/logo.png`} alt="BBSD" class="mb-5 h-10 w-auto md:mb-6 md:h-12" />
        </a>
        <p class="text-xs leading-relaxed text-gray md:text-sm">
          BBSD delivers trusted engineering and site services for global energy and
          infrastructure projects
        </p>
      </div>

      <!-- Rotterdam Office -->
      <div>
        <h4 class="mb-3 text-base font-bold text-dark md:mb-4 md:text-lg">
          Rotterdam
        </h4>
        <address class="text-xs leading-relaxed text-gray not-italic md:text-sm">
          3356 LX<br />
          Buitendijks 53, Papendrecht
        </address>
        <a
          href="https://maps.google.com/?q=Buitendijks+53+Papendrecht"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-2 inline-block text-xs font-medium text-blue-link hover:text-blue-dark md:mt-3 md:text-sm"
        >
          View on Google
        </a>
      </div>

      <!-- Nantong Office -->
      <div>
        <h4 class="mb-3 text-base font-bold text-dark md:mb-4 md:text-lg">
          Nantong
        </h4>
        <address class="text-xs leading-relaxed text-gray not-italic md:text-sm">
          No. 218 Yongxing Road<br />
          Yongxing Sub-district, Chongchuan District, Nantong City, Jiangsu
          Province, China
        </address>
        <a
          href="https://maps.google.com/?q=218+Yongxing+Road+Nantong+Jiangsu"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-2 inline-block text-xs font-medium text-blue-link hover:text-blue-dark md:mt-3 md:text-sm"
        >
          View on Google
        </a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div
      class="mt-10 flex flex-col items-center justify-between gap-4 border-t border-gray-light/20 pt-6 md:mt-12 md:flex-row md:pt-8"
    >
      <p class="text-xs text-gray-light">
        &copy; {year} - BBSD
      </p>
      <nav class="flex flex-wrap justify-center gap-4 text-xs md:gap-6 md:text-sm">
        <a href={base} class="text-gray transition-colors hover:text-dark">Home</a>
        <a href={`${base}about-us`} class="text-gray transition-colors hover:text-dark">About</a>
        <a href={`${base}contact`} class="text-gray transition-colors hover:text-dark">Contact</a>
        <a href={`${base}news`} class="text-gray transition-colors hover:text-dark">News</a>
      </nav>
    </div>
  </div>
</footer>
